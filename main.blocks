<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="Z(1OA+${F(+K+IuyrnSy" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="5Kb!uSuxPk1G%VLj6!D#"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace sistemaSeguro {" line1="" line2="    let senhaCorreta = &quot;1234&quot;" line3="    let senhaDigitada = &quot;&quot;" line4="    let visorCalculadora = &quot;&quot;" line5="" line6="    /**" line7="     * Inicializa a senha correta do sistema de cofre" line8="     * @param novaSenha a senha esperada, ex: &quot;1234&quot;" line9="     */" line10="    //% block=&quot;Definir senha do cofre para %novaSenha&quot;" line11="    //% novaSenha.defl=&quot;1234&quot;" line12="    export function configurarSenha(novaSenha: string): void {" line13="        senhaCorreta = novaSenha;" line14="        senhaDigitada = &quot;&quot;;" line15="    }" line16="" line17="    /**" line18="     * Processa a tecla pressionada no modo Cofre/Portão." line19="     * Retorna um texto de status para mandar para o LCD." line20="     * @param tecla a tecla detectada do PCF8574" line21="     */" line22="    //% block=&quot;Processar tecla %tecla no modo Cofre&quot;" line23="    export function processarCofre(tecla: string): string {" line24="        if (tecla == &quot;&quot;) return &quot;SCROLL&quot;; // Mantém o letreiro rodando" line25="" line26="        if (tecla == &quot;#&quot;) { // Tecla de confirmar" line27="            if (senhaDigitada == senhaCorreta) {" line28="                senhaDigitada = &quot;&quot;;" line29="                return &quot;ACESSO LIBERADO&quot;;" line30="            } else {" line31="                senhaDigitada = &quot;&quot;;" line32="                return &quot;SENHA INCORRETA&quot;;" line33="            }" line34="        } else if (tecla == &quot;*&quot;) { // Tecla de limpar" line35="            senhaDigitada = &quot;&quot;;" line36="            return &quot;LIMPAR&quot;;" line37="        } else {" line38="            // Limita a senha em até 8 dígitos por segurança visual" line39="            if (senhaDigitada.length &lt; 8) {" line40="                senhaDigitada += tecla;" line41="            }" line42="            // Retorna asteriscos correspondentes ao tamanho digitado" line43="            let mascarado = &quot;&quot;;" line44="            for (let i = 0; i &lt; senhaDigitada.length; i++) {" line45="                mascarado += &quot;*&quot;;" line46="            }" line47="            return mascarado;" line48="        }" line49="    }" line50="" line51="    /**" line52="     * Cria o efeito de Scroll (letreiro corrido) para textos longos no LCD 16x2." line53="     * @param texto frase completa a ser exibida" line54="     * @param passo o índice/contador atual do scroll (mude em +1 a cada ciclo)" line55="     */" line56="    //% block=&quot;Cortar texto %texto para Scroll no passo %passo&quot;" line57="    //% texto.defl=&quot;Insira a Senha:    &quot;" line58="    export function gerarTextoScroll(texto: string, passo: number): string {" line59="        if (texto.length &lt;= 16) return texto;" line60="        let indice = passo % texto.length;" line61="        let resultado = texto.substr(indice, 16);" line62="        if (resultado.length &lt; 16) {" line63="            resultado += texto.substr(0, 16 - resultado.length);" line64="        }" line65="        return resultado;" line66="    }" line67="" line68="    /**" line69="     * Processa o teclado no modo Calculadora. " line70="     * Aceita números e as operações básicas (+, -, *, /) mapeadas nas letras A, B, C, D." line71="     * Retorna o texto atualizado para exibir no visor do LCD." line72="     * @param tecla tecla lida do PCF8574" line73="     */" line74="    //% block=&quot;Processar tecla %tecla no modo Calculadora&quot;" line75="    export function processarCalculadora(tecla: string): string {" line76="        if (tecla == &quot;&quot;) return visorCalculadora;" line77="" line78="        if (tecla == &quot;A&quot;) { visorCalculadora += &quot;+&quot;; }" line79="        else if (tecla == &quot;B&quot;) { visorCalculadora += &quot;-&quot;; }" line80="        else if (tecla == &quot;C&quot;) { visorCalculadora += &quot;*&quot;; }" line81="        else if (tecla == &quot;D&quot;) { visorCalculadora += &quot;/&quot;; }" line82="        else if (tecla == &quot;*&quot;) { visorCalculadora = &quot;&quot;; } // Limpa a conta" line83="        else if (tecla == &quot;#&quot;) {" line84="            // Executa a conta básica de forma segura via código" line85="            try {" line86="                let resultado2 = avaliarExpressaoSimples(visorCalculadora);" line87="                visorCalculadora = resultado2.toString();" line88="            } catch (e) {" line89="                visorCalculadora = &quot;Erro&quot;;" line90="            }" line91="        } else {" line92="            visorCalculadora += tecla;" line93="        }" line94="" line95="        return visorCalculadora;" line96="    }" line97="" line98="    // Função interna auxiliar para resolver equações de String sem usar 'eval' inseguro" line99="    function avaliarExpressaoSimples(expr: string): number {" line100="        // Encontra o operador na string" line101="        let op = &quot;&quot;;" line102="        if (expr.indexOf(&quot;+&quot;) &gt; 0) op = &quot;+&quot;;" line103="        else if (expr.indexOf(&quot;-&quot;) &gt; 0) op = &quot;-&quot;;" line104="        else if (expr.indexOf(&quot;*&quot;) &gt; 0) op = &quot;*&quot;;" line105="        else if (expr.indexOf(&quot;/&quot;) &gt; 0) op = &quot;/&quot;;" line106="" line107="        if (op == &quot;&quot;) return parseFloat(expr);" line108="" line109="        let partes = expr.split(op);" line110="        let num1 = parseFloat(partes[0]);" line111="        let num2 = parseFloat(partes[1]);" line112="" line113="        if (op == &quot;+&quot;) return num1 + num2;" line114="        if (op == &quot;-&quot;) return num1 - num2;" line115="        if (op == &quot;*&quot;) return num1 * num2;" line116="        if (op == &quot;/&quot;) return num2 != 0 ? num1 / num2 : 0;" line117="" line118="        return 0;" line119="    }" line120="}" numlines="121"></mutation></block></statement></block></xml>