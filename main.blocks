<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="#.u4sEryE[(5B@87dJR1" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="CZi:7sxbGR-kNqf;q]Wa"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace superKitI2C {" line1="" line2="    let senhaCorreta = &quot;1234&quot;" line3="    let senhaDigitada = &quot;&quot;" line4="    let lcdAddr = 0x27" line5="    let backlightState = 0x08 // 0x08 = Ligado, 0x00 = Desligado" line6="" line7="    // Variáveis internas da Calculadora de 2 operandos" line8="    let calcNumero1 = 0" line9="    let calcNumero2 = 0" line10="    let calcOperacao = &quot;&quot;" line11="    let calcEmSegundoNumero = false" line12="    let calcVisor = &quot;0&quot;" line13="" line14="    const mapaTeclas = [" line15="        [&quot;1&quot;, &quot;2&quot;, &quot;3&quot;, &quot;A&quot;]," line16="        [&quot;4&quot;, &quot;5&quot;, &quot;6&quot;, &quot;B&quot;]," line17="        [&quot;7&quot;, &quot;8&quot;, &quot;9&quot;, &quot;C&quot;]," line18="        [&quot;*&quot;, &quot;0&quot;, &quot;#&quot;, &quot;D&quot;]" line19="    ];" line20="" line21="    // --- SEÇÃO 1: COMANDOS DO LCD I2C ---" line22="" line23="    function i2cLcdWrite(data: number, mode: number) {" line24="        let highnib = data &amp; 0xf0" line25="        let lownib = (data &lt;&lt; 4) &amp; 0xf0" line26="        pins.i2cWriteNumber(lcdAddr, highnib | mode | backlightState | 0x04, NumberFormat.Int8LE)" line27="        pins.i2cWriteNumber(lcdAddr, highnib | mode | backlightState, NumberFormat.Int8LE)" line28="        pins.i2cWriteNumber(lcdAddr, lownib | mode | backlightState | 0x04, NumberFormat.Int8LE)" line29="        pins.i2cWriteNumber(lcdAddr, lownib | mode | backlightState, NumberFormat.Int8LE)" line30="    }" line31="" line32="    /**" line33="     * Inicializa a tela LCD I2C no endereço especificado (geralmente 0x27 ou 0x3F)" line34="     */" line35="    //% block=&quot;[LCD] Inicializar no endereço I2C %addr&quot;" line36="    //% addr.defl=0x27" line37="    export function lcdInit(addr: number): void {" line38="        lcdAddr = addr" line39="        basic.pause(50)" line40="        i2cLcdWrite(0x33, 0)" line41="        basic.pause(5)" line42="        i2cLcdWrite(0x32, 0)" line43="        i2cLcdWrite(0x28, 0) // 4 bits, 2 linhas, fonte 5x8" line44="        i2cLcdWrite(0x0C, 0) // Display ON, Cursor OFF" line45="        i2cLcdWrite(0x06, 0) // Auto incrementar cursor" line46="        i2cLcdWrite(0x01, 0) // Limpar tela" line47="        basic.pause(2)" line48="    }" line49="" line50="    /**" line51="     * Limpa completamente a tela do LCD" line52="     */" line53="    //% block=&quot;[LCD] Limpar Tela&quot;" line54="    export function lcdClear(): void {" line55="        i2cLcdWrite(0x01, 0)" line56="        basic.pause(2)" line57="    }" line58="" line59="    /**" line60="     * Liga ou desliga a luz de fundo (backlight) do LCD" line61="     */" line62="    //% block=&quot;[LCD] Luz de fundo %on&quot;" line63="    //% on.shadow=&quot;toggleOnOff&quot;" line64="    export function lcdBacklight(on: boolean): void {" line65="        backlightState = on ? 0x08 : 0x00;" line66="        i2cLcdWrite(0x00, 0);" line67="    }" line68="" line69="    /**" line70="     * Exibe um texto no LCD em uma linha e coluna específicas" line71="     */" line72="    //% block=&quot;[LCD] Mostrar texto %texto na Coluna %col Linha %linha&quot;" line73="    //% col.min=0 col.max=15 linha.min=0 linha.max=1" line74="    export function lcdShowString(texto: string, col: number, linha: number): void {" line75="        let offsets = [0x00, 0x40]" line76="        i2cLcdWrite(0x80 | (offsets[linha] + col), 0)" line77="        for (let i = 0; i &lt; texto.length; i++) {" line78="            i2cLcdWrite(texto.charCodeAt(i), 1)" line79="        }" line80="    }" line81="" line82="    /**" line83="     * Cria um caractere customizado inserindo os valores binários de 5 bits para cada linha." line84="     * Use o formato 0bXXXXX (Ex: Coração L2 = 0b01010)" line85="     * @param slot número do slot de memória (0 a 7)" line86="     */" line87="    //% block=&quot;[LCD Símbolo] Criar no Slot %slot | L1 %b1 L2 %b2 L3 %b3 L4 %b4 L5 %b5 L6 %b6 L7 %b7 L8 %b8&quot;" line88="    //% slot.min=0 slot.max=7" line89="    //% b1.defl=0b00000 b2.defl=0b01010 b3.defl=0b11111 b4.defl=0b11111" line90="    //% b5.defl=0b01110 b6.defl=0b00100 b7.defl=0b00000 b8.defl=0b00000" line91="    export function lcdCriarSimboloBinario(slot: number, b1: number, b2: number, b3: number, b4: number, b5: number, b6: number, b7: number, b8: number): void {" line92="        let bytes = [b1, b2, b3, b4, b5, b6, b7, b8];" line93="        i2cLcdWrite(0x40 | (slot &lt;&lt; 3), 0);" line94="        for (let k = 0; k &lt; 8; k++) {" line95="            i2cLcdWrite(bytes[k], 1);" line96="        }" line97="    }" line98="" line99="    /**" line100="     * Desenha na tela um símbolo customizado que foi salvo previamente em um Slot (0 a 7)" line101="     */" line102="    //% block=&quot;[LCD Símbolo] Escrever Slot %slot na Coluna %col Linha %linha&quot;" line103="    //% slot.min=0 slot.max=7 col.min=0 col.max=15 linha.min=0 linha.max=1" line104="    export function lcdPrintCustomChar(slot: number, col: number, linha: number): void {" line105="        let offsets2 = [0x00, 0x40];" line106="        i2cLcdWrite(0x80 | (offsets2[linha] + col), 0);" line107="        i2cLcdWrite(slot, 1);" line108="    }" line109="" line110="" line111="    // --- SEÇÃO 2: COMANDOS DO TECLADO PCF8574 ---" line112="" line113="    /**" line114="     * Lê qual tecla foi pressionada no teclado 4x4 via expansor PCF8574" line115="     * @param pcfAddr endereço I2C do PCF8574 (geralmente 0x20 ou 0x38)" line116="     */" line117="    //% block=&quot;[Teclado] Ler tecla pressionada no endereço I2C %pcfAddr&quot;" line118="    //% pcfAddr.defl=0x20" line119="    export function lerTeclado(pcfAddr: number): string {" line120="        for (let l = 0; l &lt; 4; l++) {" line121="            let mascaraConstruida = 0xFF &amp; ~(1 &lt;&lt; l);" line122="            pins.i2cWriteNumber(pcfAddr, mascaraConstruida, NumberFormat.Int8LE);" line123="" line124="            let leitura = pins.i2cReadNumber(pcfAddr, NumberFormat.Int8LE);" line125="            let colRead = (~leitura &gt;&gt; 4) &amp; 0x0F;" line126="" line127="            if (colRead &gt; 0) {" line128="                for (let c = 0; c &lt; 4; c++) {" line129="                    if (colRead &amp; (1 &lt;&lt; c)) {" line130="                        basic.pause(200);" line131="                        return mapaTeclas[l][c];" line132="                    }" line133="                }" line134="            }" line135="        }" line136="        return &quot;&quot;;" line137="    }" line138="" line139="" line140="    // --- SEÇÃO 3: LÓGICA DE COFRE E SCROLL ---" line141="" line142="    /**" line143="     * Configura a senha correta do sistema de cofre" line144="     */" line145="    //% block=&quot;[Cofre] Definir senha para %novaSenha&quot;" line146="    //% novaSenha.defl=&quot;1234&quot;" line147="    export function configurarSenha(novaSenha: string): void {" line148="        senhaCorreta = novaSenha;" line149="        senhaDigitada = &quot;&quot;;" line150="    }" line151="" line152="    /**" line153="     * Processa a tecla digitada no modo cofre e devolve os asteriscos ou o status de validação" line154="     */" line155="    //% block=&quot;[Cofre] Processar tecla %tecla&quot;" line156="    export function processarCofre(tecla: string): string {" line157="        if (tecla == &quot;&quot;) return &quot;MANTER&quot;;" line158="" line159="        if (tecla == &quot;#&quot;) {" line160="            if (senhaDigitada == senhaCorreta) {" line161="                senhaDigitada = &quot;&quot;;" line162="                return &quot;ACESSO LIBERADO&quot;;" line163="            } else {" line164="                senhaDigitada = &quot;&quot;;" line165="                return &quot;SENHA INCORRETA&quot;;" line166="            }" line167="        } else if (tecla == &quot;*&quot;) {" line168="            senhaDigitada = &quot;&quot;;" line169="            return &quot;LIMPO&quot;;" line170="        } else {" line171="            if (senhaDigitada.length &lt; 16) {" line172="                senhaDigitada += tecla;" line173="            }" line174="            let segredo = &quot;&quot;;" line175="            for (let j = 0; j &lt; senhaDigitada.length; j++) {" line176="                segredo += &quot;*&quot;;" line177="            }" line178="            return segredo;" line179="        }" line180="    }" line181="" line182="    /**" line183="     * Gera o efeito letreiro/rolagem de texto para o LCD" line184="     */" line185="    //% block=&quot;[Efeito] Rolar texto %texto no passo %passo&quot;" line186="    //% texto.defl=&quot;Insira a Senha:    &quot;" line187="    export function gerarTextoScroll(texto: string, passo: number): string {" line188="        if (texto.length &lt;= 16) return texto;" line189="        let index = passo % texto.length;" line190="        let res = texto.substr(index, 16);" line191="        if (res.length &lt; 16) {" line192="            res += texto.substr(0, 16 - res.length);" line193="        }" line194="        return res;" line195="    }" line196="" line197="" line198="    // --- SEÇÃO 4: LÓGICA DA CALCULADORA MODULAR ---" line199="" line200="    /**" line201="     * Insere um número pressionado na lógica da calculadora" line202="     * @param numTexto O dígito em string lido do teclado (0-9)" line203="     */" line204="    //% block=&quot;[Calculadora] Inserir Dígito %numTexto&quot;" line205="    export function calcInserirDigito(numTexto: string): void {" line206="        if (numTexto == &quot;A&quot; || numTexto == &quot;B&quot; || numTexto == &quot;C&quot; || numTexto == &quot;D&quot; || numTexto == &quot;*&quot; || numTexto == &quot;#&quot; || numTexto == &quot;&quot;) return;" line207="" line208="        if (!calcEmSegundoNumero) {" line209="            if (calcVisor == &quot;0&quot;) {" line210="                calcVisor = numTexto;" line211="            } else {" line212="                calcVisor += numTexto;" line213="            }" line214="            calcNumero1 = parseFloat(calcVisor);" line215="        } else {" line216="            if (calcVisor == calcOperacao) {" line217="                calcVisor = numTexto;" line218="            } else {" line219="                calcVisor += numTexto;" line220="            }" line221="            calcNumero2 = parseFloat(calcVisor);" line222="        }" line223="    }" line224="" line225="    /**" line226="     * Define a operação matemática através das letras mapeadas (A=+, B=-, C=*, D=/)" line227="     */" line228="    //% block=&quot;[Calculadora] Definir Operação por Tecla %letca&quot;" line229="    export function calcDefirOperacao(letca: string): void {" line230="        if (letca == &quot;A&quot;) calcOperacao = &quot;+&quot;;" line231="        else if (letca == &quot;B&quot;) calcOperacao = &quot;-&quot;;" line232="        else if (letca == &quot;C&quot;) calcOperacao = &quot;*&quot;;" line233="        else if (letca == &quot;D&quot;) calcOperacao = &quot;/&quot;;" line234="        else return;" line235="" line236="        calcEmSegundoNumero = true;" line237="        calcVisor = calcOperacao;" line238="    }" line239="" line240="    /**" line241="     * Executa a conta dos dois números guardados com base na operação e retorna o resultado final" line242="     */" line243="    //% block=&quot;[Calculadora] Comando Calcular (=)&quot;" line244="    export function calcCalcular(): void {" line245="        let resultado = 0;" line246="        if (calcOperacao == &quot;+&quot;) resultado = calcNumero1 + calcNumero2;" line247="        else if (calcOperacao == &quot;-&quot;) resultado = calcNumero1 + calcNumero2;" line248="        else if (calcOperacao == &quot;*&quot;) resultado = calcNumero1 * calcNumero2;" line249="        else if (calcOperacao == &quot;/&quot;) {" line250="            if (calcNumero2 != 0) {" line251="                resultado = calcNumero1 / calcNumero2;" line252="            } else {" line253="                calcVisor = &quot;Erro /0&quot;;" line254="                return;" line255="            }" line256="        } else {" line257="            return;" line258="        }" line259="" line260="        calcVisor = resultado.toString();" line261="        calcNumero1 = resultado;" line262="        calcEmSegundoNumero = false;" line263="    }" line264="" line265="    /**" line266="     * Reseta totalmente a memória da calculadora" line267="     */" line268="    //% block=&quot;[Calculadora] Limpar Tudo (C)&quot;" line269="    export function calcLimpar(): void {" line270="        calcNumero1 = 0;" line271="        calcNumero2 = 0;" line272="        calcOperacao = &quot;&quot;;" line273="        calcEmSegundoNumero = false;" line274="        calcVisor = &quot;0&quot;;" line275="    }" line276="" line277="    /**" line278="     * Retorna o texto atual que deve ser mostrado no visor do LCD da calculadora" line279="     */" line280="    //% block=&quot;[Calculadora] Obter Texto do Visor&quot;" line281="    export function calcObterVisor(): string {" line282="        return calcVisor;" line283="    }" line284="}" numlines="285"></mutation></block></statement></block></xml>